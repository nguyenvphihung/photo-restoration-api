# Cloudinary Configuration
# Get these from: https://console.cloudinary.com/console
CLOUDINARY_CLOUD_NAME=your_cloud_name_here
CLOUDINARY_API_KEY=your_api_key_here
CLOUDINARY_API_SECRET=your_api_secret_here

# FastAPI Configuration
API_HOST=0.0.0.0
API_PORT=8000
PUBLIC_BASE_URL=http://127.0.0.1:8000
LOCAL_RESULTS_DIR=static/results

# CORS Configuration (Spring Boot backend)
SPRING_BOOT_URL=http://localhost:8080

# Conda Environments (clean rebuild without OpenMP conflicts)
ENV_ZEROSCRATCHES=rs-clean
ENV_GFPGAN=gfpgan-clean
ENV_API=api

# Worker URLs
ZEROSCRATCHES_URL=http://127.0.0.1:8001/process
COLORIZATION_URL=http://127.0.0.1:8002/colorize
GFPGAN_URL=http://127.0.0.1:8003/enhance
CODEFORMER_URL=http://127.0.0.1:8004/enhance
PIPELINE_HTTP_TIMEOUT_SECONDS=60
CODEFORMER_HTTP_TIMEOUT_SECONDS=180

# Model policy
ALLOW_MODEL_DOWNLOADS=false
